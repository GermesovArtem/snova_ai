# ==========================================
# ОСНОВНЫЕ НАСТРОЙКИ (MAIN CONFIG)
# ==========================================
# Токен вашего Telegram-бота (получить у @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Ссылка на ваш Web App (куда будет вести кнопка в боте)
# Например: https://your-domain.com
WEB_APP_URL=https://your-domain.com

# ==========================================
# ИСКУССТВЕННЫЙ ИНТЕЛЛЕКТ (KIE.AI)
# ==========================================
# API-ключ от KIE.AI
KIE_API_KEY=YOUR_KIE_API_KEY_HERE
# Базовый URL для KIE.AI (если отличается от стандартного)
KIE_BASE_URL=https://api.kie.ai/v1

# Настройки генерации
# Доступные для выбора модели (в формате JSON: {"Удобочитаемое имя на кнопке": "ID_модели_в_KIE"})
AVAILABLE_MODELS={"NanoBanana": "google/nano-banana", "NanoBanana 2": "nano-banana-2", "NanoBanana PRO": "nano-banana-pro"}
DEFAULT_MODEL=google/nano-banana

# Исходный баланс новых пользователей (выдаются только при первом старте)
STARTING_BALANCE=5.0

# Стоимость генерации для каждой из 3-х моделей (в формате JSON: {"ID_Модели_KIE": Стоимость})
CREDITS_PER_MODEL={"google/nano-banana": 1.0, "nano-banana-2": 3.0, "nano-banana-pro": 4.0}

# ==========================================
# ПЛАТЕЖНАЯ СИСТЕМА (ЮКасса / YooKassa)
# ==========================================
# ID магазина ЮКассы (Shop ID)
YOOKASSA_SHOP_ID=
# Секретный ключ (Secret Key)
YOOKASSA_SECRET_KEY=YOUR_SECRET_KEY

# Экономика: Тарифы на покупку кредитов (формат JSON: {"цена_в_рублях": количество_кредитов})
# Вы можете добавить сюда любую сетку тарифов, бот будет автоматически считывать их!
CREDIT_PACKS={"149": 30, "299": 65, "990": 270}

# ==========================================
# БАЗА ДАННЫХ (DATABASE)
# ==========================================
# Данные для запуска через docker-compose. Важно: эти переменные используются как для
# создания самой базы (PostgreSQL), так и для бота, чтобы они всегда совпадали.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nanobanana

# URL подключения к базе данных PostgreSQL (с драйвером asyncpg)
# Внимание: если запускаете через docker-compose, хост должен быть 'db' (как в docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
